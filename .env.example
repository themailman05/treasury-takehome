# AI Label Verification Prototype — environment configuration.
#
# Copy to `.env` (which config.py reads automatically) and edit:
#     cp .env.example .env
#
# Every variable below maps to a field on Settings in config.py. The DEFAULTS
# shown are the laptop / CI "mock" profile: the whole service boots and a clean
# label PASSes with NO GPU, NO Redis, and NO tesseract binary — just
# `uvicorn app:app`. Uncomment / change values to move toward the full
# self-hosted GPU stack documented in README §6.
#
# Anything left unset falls back to the Settings default in config.py.

# =============================================================================
# Inference — the self-hosted Gemma 4 vision-language model
# =============================================================================

# "mock"   -> deterministic fake extractions, no model (laptop/CI default).
# "ollama" -> self-hosted Gemma 4 on CPU via Ollama (the `docker compose` default).
# "vllm"   -> self-hosted Gemma 4 on a GPU via vLLM (production throughput target).
# Both real backends stay inside the boundary — no outbound ML traffic.
#
# LEFT COMMENTED ON PURPOSE. docker-compose auto-loads this `.env`, and the api/
# worker use `${INFERENCE_BACKEND:-ollama}` — a default that ONLY applies when the
# var is unset. If you uncomment this to `mock`, `docker compose up` would download
# Gemma 4 yet still answer with the mock model. So: leave it commented to get the
# CPU (ollama) profile under compose and the mock backend under a bare `uvicorn`
# (config.py's default). Uncomment and set `vllm` only for the GPU profile.
# INFERENCE_BACKEND=mock

# Base URL of the Ollama OpenAI-compatible server (INFERENCE_BACKEND=ollama).
#   local:           http://localhost:11434/v1
#   docker-compose:  http://ollama:11434/v1
OLLAMA_BASE_URL=http://localhost:11434/v1

# Base URL of the vLLM OpenAI-compatible server (INFERENCE_BACKEND=vllm).
#   local:           http://localhost:8001/v1
#   docker-compose:  http://vllm:8001/v1
VLLM_BASE_URL=http://localhost:8001/v1

# API key sent as `Authorization: Bearer ...`. vLLM/Ollama ignore the value but
# the OpenAI-compatible protocol requires a non-empty string.
VLLM_API_KEY=EMPTY

# Model id/tag named in the chat request.
#   Ollama (CPU) — must be a VISION-capable tag, NEVER a *-mlx tag (text-only):
#     gemma4:e2b   ~7.2 GB  lightest, best on a constrained laptop
#     gemma4:e4b   ~9.6 GB  default ("cheap deploy", README §6)
#     gemma4:12b   ~7.6 GB  higher accuracy, ~16 GB RAM
#   vLLM (GPU) — the Hugging Face id, e.g. google/gemma-4-12B / google/gemma-4-31B.
GEMMA_MODEL=gemma4:e4b

# Per-request timeout (seconds). CPU inference is slow, so this is generous by
# default; drop it toward the interactive SLA when serving on a GPU.
# INFERENCE_TIMEOUT_S=120.0

# =============================================================================
# Hugging Face — only the vLLM (GPU) profile needs this
# =============================================================================

# Token with access to the gated Gemma 4 weights, consumed by Dockerfile.vllm /
# the `vllm` compose service. NOT needed for Ollama (it pulls public gemma4 tags)
# or for the mock backend; the API + worker never use it.
HF_TOKEN=

# =============================================================================
# OCR — deterministic reading of the cropped warning region
# =============================================================================

# "mock"       -> canned canonical reading, no binary (laptop/CI default).
# "tesseract"  -> pytesseract on the cropped bbox (requires the tesseract-ocr
#                 system binary; see Dockerfile). The warning is the one field
#                 that must NOT trust the VLM transcription — see verify_warning.
# Left commented for the same reason as INFERENCE_BACKEND: compose hardcodes
# "tesseract" for its api/worker, and a bare `uvicorn` defaults to "mock".
# OCR_BACKEND=mock

# =============================================================================
# Warning verification (27 CFR 16.21)
# =============================================================================

# Canonical warning text version. A rule change (e.g. an amended cancer warning)
# is a new entry in WARNING_VERSIONS in config.py + a bump here, not a code edit.
WARNING_TEXT_VERSION=1988-ABLA

# Per-character OCR edit budget as a fraction of each component's length.
# 0.06 ~= tolerate ~1 bad char per 16. Calibrate to your OCR engine.
# OCR_ERROR_RATE=0.06

# rapidfuzz ratio (0-100) at/above which the VLM and OCR readings "agree".
# AGREEMENT_RATIO=90.0

# =============================================================================
# Field matching (brand, class/type, ABV, net contents)
# =============================================================================

# similarity >= FUZZY_PASS_THRESHOLD              -> pass
# FUZZY_REVIEW_THRESHOLD <= sim < FUZZY_PASS_*     -> needs_review (Dave's "STONE'S THROW")
# similarity <  FUZZY_REVIEW_THRESHOLD            -> fail
FUZZY_PASS_THRESHOLD=88.0
FUZZY_REVIEW_THRESHOLD=72.0

# Below this VLM confidence (0-1) a field routes to needs_review (bad photo).
MIN_FIELD_CONFIDENCE=0.40

# =============================================================================
# Batch lane / ephemeral store
# =============================================================================

# Empty -> in-process asyncio batch executor (laptop/CI default, no Redis).
# Set it to enable the Redis stream + arq worker pool (README §4).
#   docker-compose: redis://redis:6379
REDIS_URL=

# Time-to-live (seconds) for stored job results. Nothing is persisted to disk;
# results expire to satisfy Marcus's "store no sensitive data" constraint.
RESULT_TTL_SECONDS=3600

# Max worker retries before a failed batch item is dead-lettered (not stalled).
MAX_BATCH_RETRIES=3

# arq queue name shared by the API enqueue side and the worker. Match across
# the `api` and `worker` compose services.
# ARQ_QUEUE_NAME=label_jobs

# =============================================================================
# Service
# =============================================================================

# Reject uploads larger than this many bytes (per image) with HTTP 413.
# MAX_UPLOAD_BYTES=15728640   # 15 MiB

# Reject /jobs batches with more than this many images with HTTP 413.
# MAX_BATCH_IMAGES=500

# Directory of the static SPA mounted at "/".
# STATIC_DIR=static
